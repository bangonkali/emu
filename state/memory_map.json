{
  "description": "Pokémon Blue Memory Identifiers (from pret/pokered and Data Crystal)",
  "addresses": {
    "wMapLevel": {
      "hex": "0xD35E",
      "size_bytes": 1,
      "purpose": "Current internal map ID (e.g. Pallet Town = 0x00)."
    },
    "wCurrentMenuItem": {
      "hex": "0xCC26",
      "size_bytes": 1,
      "purpose": "Currently selected main menu item (topmost is 0). 0x00 means cursor is on 'CONTINUE' (if save exists) or 'NEW GAME'."
    },
    "wJoyIgnore": {
      "hex": "0xCC29",
      "size_bytes": 1,
      "purpose": "A bitmask applied to the key port for the current menu/state. When zero, the engine accepts all joypad input. During movies or cutscenes, it disables input."
    },
    "wBattleState": {
      "hex": "0xD057",
      "size_bytes": 1,
      "purpose": "Type of battle. 0 = Overworld, 1 = Wild Pokémon, 2 = Trainer, 3 = Safari Zone."
    },
    "wPartyCount": {
      "hex": "0xD163",
      "size_bytes": 1,
      "purpose": "Number of Pokémon in the player's party. Accurate reading implies the save file has successfully populated WRAM."
    },
    "wYCoord": {
      "hex": "0xD361",
      "size_bytes": 1,
      "purpose": "Player's Y screen location coordinate on the current map."
    },
    "wXCoord": {
      "hex": "0xD362",
      "size_bytes": 1,
      "purpose": "Player's X screen location coordinate on the current map."
    },
    "wBadgeFlags": {
      "hex": "0xD356",
      "size_bytes": 1,
      "purpose": "Bitmask of earned badges. Bit count = total badges (0-8)."
    },
    "wPartyMon1Species": {
      "hex": "0xD164",
      "size_bytes": 1,
      "purpose": "Species ID of party slot 1."
    },
    "wPartyMon2Species": {
      "hex": "0xD165",
      "size_bytes": 1,
      "purpose": "Species ID of party slot 2."
    },
    "wPartyMon3Species": {
      "hex": "0xD166",
      "size_bytes": 1,
      "purpose": "Species ID of party slot 3."
    },
    "wPartyMon4Species": {
      "hex": "0xD167",
      "size_bytes": 1,
      "purpose": "Species ID of party slot 4."
    },
    "wPartyMon5Species": {
      "hex": "0xD168",
      "size_bytes": 1,
      "purpose": "Species ID of party slot 5."
    },
    "wPartyMon6Species": {
      "hex": "0xD169",
      "size_bytes": 1,
      "purpose": "Species ID of party slot 6."
    },
    "wPartyMon1Level": {
      "hex": "0xD18C",
      "size_bytes": 1,
      "purpose": "Level of party Pokémon slot 1."
    },
    "wPartyMon2Level": {
      "hex": "0xD1B8",
      "size_bytes": 1,
      "purpose": "Level of party Pokémon slot 2."
    },
    "wPartyMon3Level": {
      "hex": "0xD1E4",
      "size_bytes": 1,
      "purpose": "Level of party Pokémon slot 3."
    },
    "wPartyMon4Level": {
      "hex": "0xD210",
      "size_bytes": 1,
      "purpose": "Level of party Pokémon slot 4."
    },
    "wPartyMon5Level": {
      "hex": "0xD23C",
      "size_bytes": 1,
      "purpose": "Level of party Pokémon slot 5."
    },
    "wPartyMon6Level": {
      "hex": "0xD268",
      "size_bytes": 1,
      "purpose": "Level of party Pokémon slot 6."
    },
    "wPartyMon1HP": {
      "hex": "0xD16C",
      "size_bytes": 2,
      "purpose": "Current HP of party Pokémon slot 1 (2-byte big-endian)."
    },
    "wPartyMon1MaxHP": {
      "hex": "0xD18D",
      "size_bytes": 2,
      "purpose": "Max HP of party Pokémon slot 1 (2-byte big-endian)."
    },
    "wMoney1": {
      "hex": "0xD347",
      "size_bytes": 1,
      "purpose": "Money byte 1 (BCD, most significant)."
    },
    "wMoney2": {
      "hex": "0xD348",
      "size_bytes": 1,
      "purpose": "Money byte 2 (BCD, middle)."
    },
    "wMoney3": {
